    "ad-blocker",
    "content-blocker",
    "browser-extension",
    "privacy"
  ],
  "author": "uBlock Contributors",
  "license": "GPL-3.0",
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-compat": "^4.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions"
