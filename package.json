{
  "name": "ublock",
  "version": "1.0.0",
  "description": "uBlock - Fork of gorhill/uBlock. An efficient blocker for Chromium and Firefox.",
  "main": "src/js/background.js",
  "scripts": {
    "build": "node tools/build.js",
    "build:chromium": "node tools/build.js chromium",
    "build:firefox": "node tools/build.js firefox",
    "lint": "eslint src/js/**/*.js",
    "test": "node tools/tests.js",
    "clean": "node tools/clean.js"
  },
  "repository": {
    "type": "git",
